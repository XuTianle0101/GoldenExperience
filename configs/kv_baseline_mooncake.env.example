# Recommended same-model KV offload/reuse baseline:
# vLLM + LMCache MP + Mooncake Store on local TCP + SSD.

GE_KV_BACKEND=mp
GE_ENGINE=vllm
GE_LMCACHE_MP_L2_ADAPTER_TYPE=mooncake_store

# LMCache MP server.
GE_LMCACHE_MP_HOST=127.0.0.1
GE_LMCACHE_MP_BIND_HOST=127.0.0.1
GE_LMCACHE_MP_PORT=6555
GE_LMCACHE_MP_HTTP_HOST=127.0.0.1
GE_LMCACHE_MP_HTTP_PORT=8081
GE_LMCACHE_MP_PROMETHEUS_PORT=9090
GE_LMCACHE_MP_L2_STORE_POLICY=skip_l1

# Mooncake Store.
GE_MOONCAKE_MASTER_HOST=127.0.0.1
GE_MOONCAKE_MASTER_PORT=50051
GE_MOONCAKE_METADATA_PORT=8080
GE_MOONCAKE_PROTOCOL=tcp
GE_MOONCAKE_LOCAL_HOSTNAME=127.0.0.1
GE_MOONCAKE_STORAGE_ROOT=artifacts/kv_baseline/mooncake
GE_MOONCAKE_GLOBAL_SEGMENT_SIZE=4294967296
GE_MOONCAKE_LOCAL_BUFFER_SIZE=4294967296
GE_MOONCAKE_PER_OP_WORKERS_JSON='{"lookup":2,"retrieve":8,"store":4}'

# Optional diagnostics.
# GE_LMCACHE_MP_L2_ADAPTER_TYPE=fs
