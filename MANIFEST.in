include CITATION.cff
include CONTRIBUTING.md
include README.zh-CN.md
recursive-include .github *.yml
recursive-include artifacts *.md
include artifacts/cached_kv/*.json
include artifacts/publication_v5/initialization.json
include artifacts/publication_v5/initialization_v4.json
