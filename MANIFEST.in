recursive-include artifacts/publication_v5/figures *.csv *.json *.pdf *.svg
recursive-include artifacts/publication_v5/stages *.json
recursive-include configs *.example *.json *.yaml
recursive-include docs *.md
recursive-include examples *.py
recursive-include paper *.bib *.md *.py
recursive-include recipes *.env *.md
recursive-include scripts *.ps1 *.py *.sh
recursive-include tests *.py
