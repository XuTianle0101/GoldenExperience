# Local TCP + SSD same-model KV baseline.
# Source this file, then set GE_MODEL_PATH and launch
# scripts/kv_baseline/run_vllm_lmcache_mooncake_kv_baseline.sh.

export GE_KV_BACKEND=mp
export GE_ENGINE=vllm
export GE_LMCACHE_MP_L2_ADAPTER_TYPE=mooncake_store

export GE_LMCACHE_MP_HOST=127.0.0.1
export GE_LMCACHE_MP_BIND_HOST=127.0.0.1
export GE_LMCACHE_MP_PORT=6555
export GE_LMCACHE_MP_HTTP_HOST=127.0.0.1
export GE_LMCACHE_MP_HTTP_PORT=8081
export GE_LMCACHE_MP_PROMETHEUS_PORT=9090
export GE_LMCACHE_MP_L2_STORE_POLICY=skip_l1

export GE_MOONCAKE_MASTER_HOST=127.0.0.1
export GE_MOONCAKE_MASTER_PORT=50051
export GE_MOONCAKE_METADATA_PORT=8080
export GE_MOONCAKE_PROTOCOL=tcp
export GE_MOONCAKE_LOCAL_HOSTNAME=127.0.0.1
export GE_MOONCAKE_GLOBAL_SEGMENT_SIZE=4294967296
export GE_MOONCAKE_LOCAL_BUFFER_SIZE=4294967296
export GE_MOONCAKE_PER_OP_WORKERS_JSON='{"lookup":2,"retrieve":8,"store":4}'
